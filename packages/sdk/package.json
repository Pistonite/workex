{
    "name": "@pistonite/workex",
    "version": "0.2.2",
    "type": "module",
    "private": true,
    "description": "TypeScript SDK for Workex - The in-house messaging bindgen library for my projects",
    "homepage": "https://github.com/Pistonite/workex",
    "bugs": {
        "url": "https://github.com/Pistonite/workex/issues"
    },
    "license": "MIT",
    "author": "Pistonight <pistonknight@outlook.com>",
    "files": [
        "dist/**/*",
        "src/**/*"
    ],
    "pistonight/mono-dev": {
        "lib": true,
        "publish": true
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/_dts_/src/index.d.ts"
        },
        "./internals": {
            "import": "./dist/internals.js",
            "types": "./dist/_dts_/src/internals.d.ts"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Pistonite/workex.git",
        "directory": "packages/sdk"
    },
    "dependencies": {
        "@pistonite/pure": "catalog:"
    },
    "devDependencies": {
        "mono-dev": "catalog:"
    },
    "imports": {}
}
